# Supabase (required for auth + optional DB). Project Settings → API.
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Client-safe: publishable or legacy anon JWT (either name works in this app).
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only (RLS bypass): secret or legacy service_role — never in NEXT_PUBLIC_* or client code.
# SUPABASE_SECRET_KEY=sb_secret_...
#
# Supabase Auth: Authentication → Providers → Email enabled.
# For email+password login, also enable Email/Password in the same screen.
# Authentication → URL Configuration: add Redirect URLs, e.g.
#   http://localhost:3000/auth/callback
#   https://your-domain.com/auth/callback
# Site URL should match your deployed origin.

# At least one of OPENAI_API_KEY or ANALYZE_WEBHOOK_URL should be set for /api/analyze.
# At least one of OPENAI_API_KEY or SUMMARIZE_WEBHOOK_URL should be set for /api/summarize.

# Optional: OpenAI: returns structured analysis in the same HTTP response.
OPENAI_API_KEY=sk-...

# Optional: HTTP webhook endpoint for forwarding analyze requests (e.g. n8n).
# Use the production URL (e.g. https://<sub>.app.n8n.cloud/webhook/<uuid>).
# The webhook is called with HTTP POST; payload is sent as JSON body and mirrored
# on query params (text, Text, body, message, correlationId, callbackUrl) so workflows
# that read either `$json.body.*` or `$json.query.*` keep working.
# N8N should POST results back to the callbackUrl with { correlationId, meaning, urgency, action, suspicious }.
# ANALYZE_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook-test/your-uuid

# Optional: Header Auth for the webhook (n8n Webhook node → Authentication: Header Auth).
# The app sends exactly one custom header with each webhook call.
# Example from n8n: Name=httss, Value=slll33$$$wdadmiadn8ah98
# ANALYZE_WEBHOOK_AUTH_HEADER_NAME=
# ANALYZE_WEBHOOK_AUTH_HEADER_VALUE=

# Optional: separate n8n webhook for email summarization (/api/summarize).
# Same POST contract as analyze (body + query: text, correlationId, callbackUrl).
# N8N should return JSON with { topic, urgency, actions, recommendations } (inline or via callback to /api/summarize/callback).
# Example: https://ddddffdddd.app.n8n.cloud/webhook/your-uuid
# Leave unset until you wire n8n; OPENAI_API_KEY can serve as fallback meanwhile.
# SUMMARIZE_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/your-uuid

# Optional: Header Auth for the summarize webhook (same pattern as analyze).
# SUMMARIZE_WEBHOOK_AUTH_HEADER_NAME=
# SUMMARIZE_WEBHOOK_AUTH_HEADER_VALUE=

# Optional: base URL for the callback endpoint (auto-detected from request if omitted).
# Set this if the app is behind a reverse proxy or the auto-detected URL is incorrect.
# CALLBACK_BASE_URL=https://yourdomain.com

# Optional: shared secret for authenticating callback requests from N8N.
# If set, N8N must send x-callback-secret header with this value.
# CALLBACK_SECRET=

# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Prisma ↔ Supabase Postgres (required for migrations + runtime DB access).
# Use the Session Pooler URLs from Supabase → Connect → Session pool if you need IPv4-compatible DB access.
# Replace [YOUR-PASSWORD] with the database password (Settings → Database); URL-encode special characters in passwords.
#
# Pooled URL (PgBouncer, port 6543) — typical default for DATABASE_URL / serverless connections:
# DATABASE_URL="postgresql://postgres.lwhyndtphuubmlibbbjp:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Direct session mode on pooler host (port 5432) — required by Prisma for migrations (matches dashboard "Direct connection"):
# DIRECT_URL="postgresql://postgres.lwhyndtphuubmlibbbjp:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
#
# Direct database host (`db.` — may require IPv6 or IPv4 add-on; dashboard often recommends Session Pooler instead):
# postgresql://postgres:[YOUR-PASSWORD]@db.lwhyndtphuubmlibbbjp.supabase.co:5432/postgres

# Billing (non-Stripe): Lemon Squeezy default provider.
# Set NEXT_PUBLIC_APP_URL for redirects after checkout.
# BILLING_PROVIDER=lemonsqueezy
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# LEMONSQUEEZY_API_KEY=lsq_...
# LEMONSQUEEZY_STORE_ID=12345
# LEMONSQUEEZY_VARIANT_ID=12345
# LEMONSQUEEZY_WEBHOOK_SECRET=...
# Optional: direct link to Lemon Squeezy customer portal.
# LEMONSQUEEZY_CUSTOMER_PORTAL_URL=https://my-store.lemonsqueezy.com/billing
#
# Premium gating is always enforced for /api/analyze.
# During testing, checkout can auto-activate a 0-shekel plan:
# BILLING_ZERO_PRICE_TEST_MODE=true
