# At least one of OPENAI_API_KEY or ANALYZE_WEBHOOK_URL should be set for /api/analyze.

# Optional: OpenAI — returns structured analysis in the same HTTP response.
OPENAI_API_KEY=sk-...

# Optional: HTTP webhook endpoint for forwarding analyze requests.
# The webhook is called with GET query params: text, Text, body, message, correlationId, callbackUrl.
# N8N should POST results back to the callbackUrl with { correlationId, meaning, urgency, action, suspicious }.
ANALYZE_WEBHOOK_URL=https://matan-cursor.app.n8n.cloud/webhook-test/c41da64f-ec06-461c-a70b-fffc3b61339f

# Optional: base URL for the callback endpoint (auto-detected from request if omitted).
# Set this if the app is behind a reverse proxy or the auto-detected URL is incorrect.
# CALLBACK_BASE_URL=https://yourdomain.com

# Optional: shared secret for authenticating callback requests from N8N.
# If set, N8N must send x-callback-secret header with this value.
# CALLBACK_SECRET=

# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: SQLite file URL for logging analyses locally.
# Omit on serverless (e.g. Vercel) unless you use a hosted DB — see README.
DATABASE_URL="file:./dev.db"
