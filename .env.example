# At least one of OPENAI_API_KEY or MAKE_WEBHOOK_URL should be set for /api/analyze.

# Optional: OpenAI — returns structured analysis in the same HTTP response.
OPENAI_API_KEY=sk-...

# Optional: Make.com custom webhook (full URL, e.g. https://hook.eu2.make.com/your-token)
# The app POSTs JSON: { "text": "...", "correlationId": "<uuid>" }.
MAKE_WEBHOOK_URL=

# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: SQLite file URL for logging analyses locally.
# Omit on serverless (e.g. Vercel) unless you use a hosted DB — see README.
DATABASE_URL="file:./dev.db"
