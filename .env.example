# This app runs locally with no authentication. There is no login/signup,
# and no Supabase configuration is required.

# At least one of OPENAI_API_KEY or ANALYZE_WEBHOOK_URL should be set for /api/analyze.
# SUMMARIZE_WEBHOOK_URL is used for /api/summarize (Cursor automation webhook).

# Cursor Automations webhooks require auth (URL alone returns 401).
# In cursor.com/automations → your automation → Webhook → "Generate auth header"
# Paste the crsr_... token below (with or without "Bearer " prefix).
# CURSOR_WEBHOOK_AUTH_TOKEN=crsr_...          # optional: same token for both routes
# ANALYZE_WEBHOOK_AUTH_TOKEN=crsr_...         # phishing automation
# SUMMARIZE_WEBHOOK_AUTH_TOKEN=crsr_...       # summarize automation
# Or set a custom header pair instead:
# ANALYZE_WEBHOOK_AUTH_HEADER_NAME=Authorization
# ANALYZE_WEBHOOK_AUTH_HEADER_VALUE=Bearer crsr_...

# Optional: OpenAI: returns structured analysis in the same HTTP response.
OPENAI_API_KEY=sk-...

# Cursor automation webhook for phishing/scam analyze (home page).
# POST body includes { text, prompt, correlationId, callbackUrl }.
# Response should be JSON with { meaning, urgency, action, suspicious }.
# ANALYZE_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/your-uuid

# Optional: Header Auth for the webhook (n8n Webhook node → Authentication: Header Auth).
# The app sends exactly one custom header with each webhook call.
# Example from n8n: Name=httss, Value=slll33$$$wdadmiadn8ah98
# ANALYZE_WEBHOOK_AUTH_HEADER_NAME=
# ANALYZE_WEBHOOK_AUTH_HEADER_VALUE=

# Cursor automation webhook for summarize feature
# SUMMARIZE_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/your-uuid

# Optional: base URL for the analyze callback endpoint (auto-detected from request if omitted).
# Set this if the app is behind a reverse proxy or the auto-detected URL is incorrect.
# CALLBACK_BASE_URL=https://yourdomain.com

# Optional: shared secret for authenticating callback requests from N8N.
# If set, N8N must send x-callback-secret header with this value.
# CALLBACK_SECRET=

# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: Postgres database for Prisma (billing persistence). Not required on
# localhost — billing falls back to an in-memory / cookie test mode when unset.
# DATABASE_URL="postgresql://user:[YOUR-PASSWORD]@localhost:5432/postgres"
# DIRECT_URL="postgresql://user:[YOUR-PASSWORD]@localhost:5432/postgres"

# Billing (non-Stripe): Lemon Squeezy default provider.
# Set NEXT_PUBLIC_APP_URL for redirects after checkout.
# BILLING_PROVIDER=lemonsqueezy
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# LEMONSQUEEZY_API_KEY=lsq_...
# LEMONSQUEEZY_STORE_ID=12345
# LEMONSQUEEZY_VARIANT_ID=12345
# LEMONSQUEEZY_WEBHOOK_SECRET=...
# Optional: direct link to Lemon Squeezy customer portal.
# LEMONSQUEEZY_CUSTOMER_PORTAL_URL=https://my-store.lemonsqueezy.com/billing
#
# Premium gating is always enforced for /api/analyze.
# During testing, checkout can auto-activate a 0-shekel plan:
# BILLING_ZERO_PRICE_TEST_MODE=true
