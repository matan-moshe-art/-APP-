# Local app — no login or billing required.

# Postgres (optional but recommended for AI training logs)
# POSTGRES_URL=postgresql://user:password@localhost:5432/hebrew_analyzer

# Cursor Automations webhooks (short + long, per feature).
# In cursor.com/automations → automation → Webhook → "Generate auth header"
# Paste crsr_... tokens (with or without "Bearer " prefix).

# Summarize — short messages
# SUMMARIZE_WEBHOOK_URL_SHORT=https://api2.cursor.sh/automations/webhook/your-uuid
# SUMMARIZE_WEBHOOK_AUTH_TOKEN_SHORT=crsr_...

# Summarize — long / PDF text
# SUMMARIZE_WEBHOOK_URL_LONG=https://api2.cursor.sh/automations/webhook/your-uuid
# SUMMARIZE_WEBHOOK_AUTH_TOKEN_LONG=crsr_...

# Phishing/scam analyze — short messages
# ANALYZE_WEBHOOK_URL_SHORT=https://api2.cursor.sh/automations/webhook/your-uuid
# ANALYZE_WEBHOOK_AUTH_TOKEN_SHORT=crsr_...

# Phishing/scam analyze — long / PDF text
# ANALYZE_WEBHOOK_URL_LONG=https://api2.cursor.sh/automations/webhook/your-uuid
# ANALYZE_WEBHOOK_AUTH_TOKEN_LONG=crsr_...

# Legacy (optional): same as *_SHORT if you only set one pair per feature
# ANALYZE_WEBHOOK_URL=...
# ANALYZE_WEBHOOK_AUTH_TOKEN=...
# SUMMARIZE_WEBHOOK_URL=...
# SUMMARIZE_WEBHOOK_AUTH_TOKEN=...

# Optional shared fallback when per-route *_AUTH_TOKEN_* is unset
# CURSOR_WEBHOOK_AUTH_TOKEN=crsr_...

# Optional: OpenAI fallback for /api/analyze when webhook output is unusable.
OPENAI_API_KEY=sk-...

# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
