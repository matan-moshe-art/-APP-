// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Analysis {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now()) @map("created_at")
  inputText        String   @map("input_text")
  resultMeaning    String   @map("result_meaning")
  resultUrgency    String   @map("result_urgency")
  resultAction     String   @map("result_action")
  resultSuspicious String   @map("result_suspicious")
  modelUsed        String   @map("model_used")
  durationMs       Int      @map("duration_ms")

  @@map("analyses")
}

model AppUser {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  supabaseUserId String   @unique @map("supabase_user_id")
  email          String?  @unique
  displayName    String?  @map("display_name")
  avatarUrl      String?  @map("avatar_url")
  lastSignInAt   DateTime @default(now()) @map("last_sign_in_at")

  @@map("app_users")
}

model BillingCustomer {
  id                 Int            @id @default(autoincrement())
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  userId             String         @unique @map("user_id")
  provider           String         @map("provider")
  providerCustomerId String         @unique @map("provider_customer_id")
  email              String?        @map("email")
  subscriptions      Subscription[]

  @@map("billing_customers")
}

model Subscription {
  id                     Int             @id @default(autoincrement())
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  customerId             Int             @map("customer_id")
  provider               String          @map("provider")
  providerSubscriptionId String          @unique @map("provider_subscription_id")
  status                 SubscriptionStatus
  planId                 String?         @map("plan_id")
  currentPeriodStart     DateTime?       @map("current_period_start")
  currentPeriodEnd       DateTime?       @map("current_period_end")
  cancelAtPeriodEnd      Boolean         @default(false) @map("cancel_at_period_end")
  cancelledAt            DateTime?       @map("cancelled_at")
  customer               BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
  @@map("subscriptions")
}

model BillingWebhookEvent {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now()) @map("created_at")
  provider       String
  eventId        String   @map("event_id")
  eventType      String   @map("event_type")
  payload        String
  processedAt    DateTime @default(now()) @map("processed_at")
  processingNote String?  @map("processing_note")

  @@unique([provider, eventId])
  @@map("billing_webhook_events")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  paused
  incomplete
  incomplete_expired
}
